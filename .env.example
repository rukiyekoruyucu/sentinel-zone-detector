FLASK_ENV=development
SECRET_KEY=sentinel-change-me-in-production

# Model dosya yolları (OpenVINO .xml)
DET_MODEL=models/ov/yolo11n.xml
POSE_MODEL=models/ov/rtmpose-t.xml
XG_MODEL=models/ov/xg_detector.xml

# Eşik değerleri
DET_SCORE_THR=0.35
POSE_KPT_THR=0.30
