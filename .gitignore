# ============================================================
#  SENTINEL — .gitignore
#  Bu dosya, GitHub'a gönderilmeyecek dosyaları tanımlar.
# ============================================================

# ─── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/
*.spec

# ─── Virtual Environments ────────────────────────────────────
.venv/
venv/
env/
ENV/
.env.local

# ─── Secrets & Environment ───────────────────────────────────
# .env.example is intentionally NOT ignored (template for users)
.env

# ─── Database ────────────────────────────────────────────────
*.db
*.sqlite3
instance/

# ─── Uploads & User Data ─────────────────────────────────────
uploads/*
!uploads/.gitkeep
snapshots/*
!snapshots/.gitkeep

# ─── Compiled / Binary Model Files ───────────────────────────
models/ov/*
!models/ov/.gitkeep
*.pt
*.onnx
*.bin
*.xml

# ─── 🔒 PROPRIETARY ALGORITHMS (Company Confidential) ────────
#  Bu dosyalar şirkete ait algoritma kodu içermektedir.
#  Do NOT commit these files.
inference/xg/
inference/xg_detector.py
inference/base_model.py
catboost_info/

# ─── Training Artifacts ──────────────────────────────────────
*.pkl
*.joblib
*.model
*.cbm

# ─── Logs ────────────────────────────────────────────────────
*.log
logs/

# ─── OS / IDE ────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~

# ─── Personal / Academic Reports ─────────────────────────────
210315020_*.md
*_Final_Report_*.md

# ─── Misc ────────────────────────────────────────────────────
*.bak
*.tmp
fix_use_case_*.py
generate_report.py
{inference,models*
{models,auth*
